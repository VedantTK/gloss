# ==============================
# Gloss – Environment Variables
# ==============================
# Copy this file to .env and fill in values before running docker-compose

# --- Backend ---
DEBUG=false
CACHE_TTL_SECONDS=300          # How long to cache yfinance responses (seconds)
TOP_N_STOCKS=10                # Number of stocks per panel

# --- Frontend ---
# URL the browser uses to reach the backend API
# In Docker Compose: keep as http://localhost:8000 (Nginx proxies /api/ to backend)
